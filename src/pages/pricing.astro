---
import Base from '../layouts/Base.astro';
import {
  VAULTYX_TIERS,
  APP_UNLOCK_PRICES,
  fmtUsd,
  annualSavingsPct,
  appStoreUrl,
} from '../data/pricing';

// Derived values for hero + plan card
const minVaultyxMonthly = Math.min(...VAULTYX_TIERS.map((t) => t.monthly_usd));
const featuredTier = VAULTYX_TIERS.find((t) => t.featured) ?? VAULTYX_TIERS[1];
const vaultyxAnnualPct = annualSavingsPct(featuredTier.monthly_usd, featuredTier.annual_usd);
const minUtilityUnlock = Math.min(
  ...Object.values(APP_UNLOCK_PRICES)
    .map((p) => p.unlock_usd)
    .filter((v): v is number => v != null),
);
const maxUtilityUnlock = Math.max(
  ...Object.values(APP_UNLOCK_PRICES)
    .map((p) => p.unlock_usd)
    .filter((v): v is number => v != null),
);
const vaultyxAppStore = appStoreUrl('vaultyx');

const tiersJsonLd = VAULTYX_TIERS.map((t) => ({
  '@type': 'Offer',
  priceCurrency: 'USD',
  price: t.monthly_usd.toFixed(2),
  name: `Vaultyx ${t.capacity} monthly`,
}));
---
<Base
  title={`Pricing — Katafract`}
  description={`App-specific pricing. Haven DNS is free. Utility apps are ${fmtUsd(minUtilityUnlock)}–${fmtUsd(maxUtilityUnlock)} one-time. Vaultyx encrypted storage starts at ${fmtUsd(minVaultyxMonthly)}/month. No platform bundle until WraithVPN ships.`}
  section="pricing"
>
  <link slot="head" rel="stylesheet" href="/style.css" />
  <style slot="head" is:global set:html={`
    .pricing-hero { padding: 8rem 0 4rem; text-align: center; }
    .pricing-hero h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.5rem,6vw,4rem); font-weight: 700; margin-bottom: 1rem; line-height: 1.1; }
    .pricing-hero p { color: #8C94A6; font-size: 1.1rem; max-width: 620px; margin: 0 auto 2.5rem; line-height: 1.7; }
    .plans-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; max-width: 1100px; margin: 2rem auto 5rem; }
    .plan-card { background: #0a0a14; border: 1px solid rgba(100,100,120,.15); border-radius: 20px; padding: 2.25rem 2rem; position: relative; overflow: hidden; display: flex; flex-direction: column; }
    .plan-card.featured { border-color: rgba(255,0,110,.3); }
    .plan-card.featured::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, #FF006E, rgba(255,0,110,.2)); }
    .plan-card.future { border-style: dashed; opacity: .85; }
    .plan-label { font-family: 'JetBrains Mono', monospace; font-size: .65rem; letter-spacing: .25em; text-transform: uppercase; margin-bottom: 1rem; }
    .plan-name { font-family: 'Cormorant Garamond', serif; font-size: 1.85rem; font-weight: 700; margin-bottom: .5rem; }
    .plan-tagline { color: #8C94A6; font-size: .9rem; margin-bottom: 1.75rem; line-height: 1.5; }
    .plan-price { margin-bottom: 1.75rem; }
    .plan-price .amount { font-family: 'JetBrains Mono', monospace; font-size: 2.25rem; font-weight: 600; }
    .plan-price .period { color: #8C94A6; font-size: .85rem; }
    .plan-price .annual-note { font-family: 'JetBrains Mono', monospace; font-size: .7rem; color: #4ADE80; margin-top: .25rem; }
    .plan-features { list-style: none; margin-bottom: 1.75rem; display: flex; flex-direction: column; gap: .65rem; flex: 1; padding: 0; }
    .plan-features li { display: flex; align-items: flex-start; gap: .6rem; font-size: .875rem; color: #8C94A6; line-height: 1.5; }
    .plan-features li .check { flex-shrink: 0; margin-top: 1px; }
    .plan-features li.dim { opacity: .55; }
    .plan-cta { display: block; width: 100%; padding: .85rem; border-radius: 10px; text-align: center; font-family: 'JetBrains Mono', monospace; font-size: .875rem; font-weight: 500; cursor: pointer; text-decoration: none; transition: opacity .2s; box-sizing: border-box; }
    .plan-cta:hover { opacity: .85; text-decoration: none; }
    .plan-cta.primary { background: linear-gradient(135deg, rgba(255,0,110,.8), rgba(255,0,110,.5)); color: #fff; border: 1px solid rgba(255,0,110,.4); }
    .plan-cta.secondary { background: transparent; color: #4ADE80; border: 1px solid rgba(74,222,128,.3); }
    .plan-cta.cyan { background: transparent; color: #00F0FF; border: 1px solid rgba(0,240,255,.3); }
    .plan-cta.disabled { background: transparent; color: #4a5060; border: 1px dashed rgba(100,100,120,.3); cursor: not-allowed; }
    .plan-cta.disabled:hover { opacity: 1; }

    .dns-free-box { background: #0a0a14; border: 1px solid rgba(100,100,120,.15); border-radius: 16px; padding: 2.5rem; max-width: 700px; margin: 0 auto 6rem; text-align: center; }
    .dns-free-box h2 { font-family: 'Cormorant Garamond', serif; font-size: 1.75rem; margin-bottom: .75rem; }
    .dns-free-box p { color: #8C94A6; font-size: .9rem; margin-bottom: 1.75rem; line-height: 1.7; }

    .vaultyx-tiers { max-width: 900px; margin: 0 auto 5rem; }
    .vaultyx-tiers h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; text-align: center; margin-bottom: 1.5rem; }
    .vaultyx-tier-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; }
    .vaultyx-tier { background: rgba(255,0,110,.03); border: 1px solid rgba(255,0,110,.15); border-radius: 12px; padding: 1.5rem 1.25rem; text-align: center; }
    .vaultyx-tier.featured { border-color: rgba(255,0,110,.35); background: rgba(255,0,110,.06); }
    .vaultyx-tier .cap { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 700; color: #fff; }
    .vaultyx-tier .price { font-family: 'JetBrains Mono', monospace; font-size: 1.05rem; color: #FF006E; margin-top: .35rem; }
    .vaultyx-tier .annual { font-family: 'JetBrains Mono', monospace; font-size: .7rem; color: #8C94A6; margin-top: .25rem; }

    .future-bundle-box { max-width: 720px; margin: 0 auto 6rem; padding: 2.5rem 2rem; background: linear-gradient(135deg, rgba(255,0,110,.04), rgba(255,0,110,.01)); border: 1px dashed rgba(255,0,110,.25); border-radius: 16px; text-align: center; }
    .future-bundle-box h2 { font-family: 'Cormorant Garamond', serif; font-size: 1.75rem; margin-bottom: .75rem; }
    .future-bundle-box p { color: #8C94A6; font-size: .95rem; line-height: 1.7; max-width: 540px; margin: 0 auto .75rem; }
    .future-bundle-box .small { font-family: 'JetBrains Mono', monospace; font-size: .72rem; color: #4a5060; margin-top: 1.25rem; letter-spacing: .12em; text-transform: uppercase; }

    .faq { max-width: 680px; margin: 0 auto 6rem; }
    .faq h2 { font-family: 'Cormorant Garamond', serif; font-size: 2rem; text-align: center; margin-bottom: 2.5rem; }
    .faq-item { border-bottom: 1px solid rgba(100,100,120,.1); padding: 1.25rem 0; cursor: pointer; }
    .faq-q { font-weight: 600; font-size: .95rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
    .faq-q::after { content: '+'; color: #8C94A6; font-size: 1.2rem; flex-shrink: 0; transition: transform .2s; }
    .faq-item.open .faq-q::after { transform: rotate(45deg); }
    .faq-a { color: #8C94A6; font-size: .9rem; line-height: 1.7; max-height: 0; overflow: hidden; transition: max-height .3s ease, padding .3s ease; }
    .faq-item.open .faq-a { max-height: 400px; padding-top: .75rem; }

    @media (max-width: 640px) {
      .plans-grid { grid-template-columns: 1fr; }
      .plan-card { padding: 1.75rem 1.5rem; }
    }
  `}></style>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify([
    {
      '@context': 'https://schema.org',
      '@type': 'Product',
      name: 'Haven',
      description: 'Encrypted DNS with ad, tracker, and malware blocking. Free. No account, no payment, no logs.',
      brand: { '@type': 'Brand', name: 'Katafract' },
      url: 'https://katafract.com/dns',
      offers: [{ '@type': 'Offer', priceCurrency: 'USD', price: '0' }],
    },
    {
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: 'Vaultyx',
      operatingSystem: 'iOS',
      applicationCategory: 'SecurityApplication',
      description: 'Zero-knowledge encrypted cloud storage. AES-256-GCM on your device, keys in your iOS Keychain, replicated across 3 datacenters in 2 jurisdictions.',
      offers: tiersJsonLd,
      author: { '@type': 'Organization', name: 'Katafract LLC' },
    },
  ])}>
  </script>

  <main>
    <div class="container">

      <!-- Hero -->
      <div class="pricing-hero">
        <div class="section-label-sm fm" style="font-size:.65rem;color:#FF006E;letter-spacing:.3em;text-transform:uppercase;margin-bottom:1rem">Pricing</div>
        <h1>Buy what you need.<br>Nothing you don't.</h1>
        <p>App-specific pricing. Haven DNS is free. Utility apps are one-time, {fmtUsd(minUtilityUnlock)} to {fmtUsd(maxUtilityUnlock)}. Vaultyx encrypted storage is a subscription that scales by capacity. No platform bundle until WraithVPN ships and we can deliver one we'd buy ourselves.</p>
      </div>

      <!-- Plans -->
      <div class="plans-grid">

        <!-- Armor Apps (one-time) -->
        <div class="plan-card">
          <div class="plan-label" style="color:#00F0FF">Standalone apps</div>
          <div class="plan-name">Armor Apps</div>
          <div class="plan-tagline">Device-side privacy tools. Free to try, {fmtUsd(minUtilityUnlock)}–{fmtUsd(maxUtilityUnlock)} one-time. No subscription.</div>
          <div class="plan-price">
            <div class="amount" style="color:#00F0FF">from {fmtUsd(minUtilityUnlock)}</div>
            <div class="period">one-time per app</div>
          </div>
          <ul class="plan-features">
            <li><span class="check" style="color:#00F0FF">✓</span> ExifArmor — strip photo metadata · {fmtUsd(APP_UNLOCK_PRICES.exifarmor.unlock_usd!)} unlock</li>
            <li><span class="check" style="color:#00F0FF">✓</span> ParkArmor — parking saver · {fmtUsd(APP_UNLOCK_PRICES.parkarmor.unlock_usd!)} unlock</li>
            <li><span class="check" style="color:#00F0FF">✓</span> DocArmor — encrypted ID vault · {fmtUsd(APP_UNLOCK_PRICES.docarmor.unlock_usd!)} unlock</li>
            <li><span class="check" style="color:#00F0FF">✓</span> SafeOpen — link inspector · Free + credits</li>
            <li><span class="check" style="color:#00F0FF">✓</span> Everything stays on your device</li>
            <li><span class="check" style="color:#00F0FF">✓</span> No account · no logs · no tracking</li>
          </ul>
          <a href="/#apps" class="plan-cta cyan">See the apps →</a>
        </div>

        <!-- Haven (free) -->
        <div class="plan-card">
          <div class="plan-label" style="color:#4ADE80">Haven · Always Free</div>
          <div class="plan-name">Haven DNS</div>
          <div class="plan-tagline">Encrypted DNS with ad, tracker, and malware blocking. No account, no payment, no logs.</div>
          <div class="plan-price">
            <div class="amount" style="color:#4ADE80">Free</div>
            <div class="period">forever</div>
          </div>
          <ul class="plan-features">
            <li><span class="check" style="color:#4ADE80">✓</span> Encrypted DNS (DoH + DoT)</li>
            <li><span class="check" style="color:#4ADE80">✓</span> Ad + tracker blocking</li>
            <li><span class="check" style="color:#4ADE80">✓</span> Malware + phishing domains blocked</li>
            <li><span class="check" style="color:#4ADE80">✓</span> Works on iOS, Android, macOS, Windows, routers</li>
            <li><span class="check" style="color:#4ADE80">✓</span> No logs · no account needed</li>
          </ul>
          <a href="/dns" class="plan-cta secondary">Set up Haven →</a>
        </div>

        <!-- Vaultyx (subscription) -->
        <div class="plan-card featured">
          <div style="position:absolute;top:0;right:0;width:200px;height:200px;background:radial-gradient(circle,rgba(255,0,110,.08) 0%,transparent 70%);pointer-events:none"></div>
          <div class="plan-label" style="color:#FF006E">Vaultyx · Live on iOS</div>
          <div class="plan-name">Vaultyx</div>
          <div class="plan-tagline">Encrypted cloud storage we cannot read. Pick a capacity. Subscribe in the app.</div>
          <div class="plan-price">
            <div class="amount" style="color:#FF006E">from {fmtUsd(minVaultyxMonthly)}</div>
            <div class="period">/ month · {VAULTYX_TIERS[0].capacity} to {VAULTYX_TIERS[VAULTYX_TIERS.length - 1].capacity}</div>
            <div class="annual-note">~{vaultyxAnnualPct}% off with annual billing</div>
          </div>
          <ul class="plan-features">
            <li><span class="check" style="color:#FF006E">✓</span> AES-256-GCM client-side encryption</li>
            <li><span class="check" style="color:#FF006E">✓</span> Keys live in your iOS Keychain</li>
            <li><span class="check" style="color:#FF006E">✓</span> 3 datacenters, 2 jurisdictions (US + Canada)</li>
            <li><span class="check" style="color:#FF006E">✓</span> Standard S3 API at vaultyx.objstore.io</li>
            <li><span class="check" style="color:#FF006E">✓</span> No content scanning · no AI training</li>
            <li><span class="check" style="color:#FF006E">✓</span> Cancel anytime in App Store</li>
          </ul>
          {vaultyxAppStore && (
            <a href={vaultyxAppStore} class="plan-cta primary plausible-event-name=AppStore+Click plausible-event-app=vaultyx">Get Vaultyx on the App Store →</a>
          )}
          <p style="margin-top:.75rem;text-align:center;font-size:.72rem;color:#4a5060;font-family:'JetBrains Mono',monospace">Subscription handled by Apple — billed via your App Store account</p>
        </div>

        <!-- Future bundle teaser -->
        <div class="plan-card future">
          <div class="plan-label" style="color:#8C94A6">Coming next</div>
          <div class="plan-name">A platform bundle</div>
          <div class="plan-tagline">When WraithVPN ships, we'll combine VPN, encrypted storage, and the utility apps into a single subscription that beats buying them separately.</div>
          <div class="plan-price">
            <div class="amount" style="color:#8C94A6;font-size:1.5rem">Not yet</div>
            <div class="period">we'll announce when it's real</div>
          </div>
          <ul class="plan-features">
            <li class="dim"><span class="check">○</span> WraithVPN with global exits</li>
            <li class="dim"><span class="check">○</span> Vaultyx storage included</li>
            <li class="dim"><span class="check">○</span> All utility apps unlocked</li>
            <li class="dim"><span class="check">○</span> Token identity (no email required)</li>
            <li><span class="check" style="color:#8C94A6">✓</span> Subscribe to ship notifications below</li>
          </ul>
          <a href="/#signup" class="plan-cta disabled">Notify me →</a>
        </div>

      </div>

      <!-- Vaultyx capacity tiers -->
      <div class="vaultyx-tiers">
        <h3>Vaultyx capacity tiers</h3>
        <div class="vaultyx-tier-grid">
          {VAULTYX_TIERS.map((t) => (
            <div class={`vaultyx-tier${t.featured ? ' featured' : ''}`}>
              <div class="cap">{t.capacity}</div>
              <div class="price">{fmtUsd(t.monthly_usd)} / mo</div>
              <div class="annual">{fmtUsd(t.annual_usd)}/yr — ~{fmtUsd(t.annual_usd / 12).replace('$', '$')}/mo</div>
            </div>
          ))}
        </div>
        <p style="text-align:center;color:#4a5060;font-size:.78rem;font-family:'JetBrains Mono',monospace;margin-top:1.25rem">All tiers · unlimited bandwidth · S3 API · same encryption · same architecture</p>
      </div>

      <!-- Free Haven DNS box -->
      <div class="dns-free-box">
        <h2>Haven DNS — always free, no account</h2>
        <p>Basic DNS protection — ad blocking, tracker blocking, malware filtering — at no cost. Just point your DNS to our servers. Nothing to install, no sign-up.</p>
        <div style="display:flex;flex-direction:column;align-items:center;gap:1rem;margin:1.5rem 0">
          <div style="font-family:'JetBrains Mono',monospace;font-size:1.15rem;color:#4ADE80;background:rgba(74,222,128,0.08);border:1px solid rgba(74,222,128,0.25);border-radius:8px;padding:.75rem 1.5rem;letter-spacing:.04em">dns.katafract.com</div>
          <div style="font-family:'JetBrains Mono',monospace;font-size:.7rem;color:#8C94A6;letter-spacing:.15em;text-transform:uppercase">iPhone · Android · macOS · Windows · Router</div>
        </div>
        <a href="/dns" style="font-family:'JetBrains Mono',monospace;font-size:.8rem;color:#4ADE80">Setup guide →</a>
      </div>

      <!-- Future bundle context -->
      <div class="future-bundle-box">
        <h2>Why no bundle right now</h2>
        <p>The bundle worth selling is one that includes WraithVPN — encrypted transit, our own exit nodes, no logs. WraithVPN is built and submitted, but Apple's VPN-app program requires us to be a registered business account, and that conversion is still in progress.</p>
        <p>Until that lands, every app is sold standalone with honest, app-specific pricing. We'd rather wait than sell a bundle missing its anchor.</p>
        <p class="small">no roadmap promises &middot; no early-bird sign-ups &middot; subscribe to ship notifications below to be told when it lands</p>
      </div>

      <!-- FAQ -->
      <div class="faq">
        <h2>Questions</h2>

        <div class="faq-item">
          <div class="faq-q">Why no monthly subscription for the platform yet?</div>
          <div class="faq-a">The honest answer: WraithVPN — the network piece of the platform — hasn't shipped to the App Store. Apple's VPN-app program requires Katafract LLC to be converted to a business account, and that's still in progress. Selling an "Enclave" subscription before VPN works would be selling a half-product. So we don't.</div>
        </div>

        <div class="faq-item">
          <div class="faq-q">How do I pay for Vaultyx?</div>
          <div class="faq-a">In the iOS app. Subscriptions are managed through your App Store account — Apple handles billing, refunds, and cancellations. {VAULTYX_TIERS.length} capacity tiers: {VAULTYX_TIERS.map((t) => `${t.capacity} (${fmtUsd(t.monthly_usd)}/mo)`).join(', ')}. Annual billing saves ~{vaultyxAnnualPct}%. Switch tiers any time.</div>
        </div>

        <div class="faq-item">
          <div class="faq-q">Are there logs of what I store?</div>
          <div class="faq-a">No content logs — we can't see your files, ever. Encryption is client-side; the encryption keys live in your iOS Keychain, not on our servers. We see ciphertext only. We do keep minimal operational metadata (file sizes, request timestamps) to bill capacity and keep the service running.</div>
        </div>

        <div class="faq-item">
          <div class="faq-q">What happens if I cancel Vaultyx?</div>
          <div class="faq-a">Your data stays for a 30-day grace period after cancellation, then is permanently deleted. You can re-subscribe within that window without losing anything. Export anytime via the app or the S3 API at vaultyx.objstore.io.</div>
        </div>

        <div class="faq-item">
          <div class="faq-q">Do the utility apps need a subscription?</div>
          <div class="faq-a">No. ExifArmor, ParkArmor, DocArmor, and SafeOpen are standalone iOS apps with one-time unlocks — buy once, own it. SafeOpen has free scans plus optional credit packs (consumed by AI link summaries). No accounts, no recurring billing.</div>
        </div>

        <div class="faq-item">
          <div class="faq-q">Can I use Haven DNS without paying for anything else?</div>
          <div class="faq-a">Yes — Haven is free, forever, no account required. Install the DNS profile from <a href="/dns">/dns</a> and it works on every device that supports DoH/DoT. You don't need to be a Katafract customer of any other product.</div>
        </div>

        <div class="faq-item">
          <div class="faq-q">When will WraithVPN ship and the bundle launch?</div>
          <div class="faq-a">We don't commit to dates we don't control. The Apple business-account conversion is in process; WraithVPN is built, tested, and uploaded; the bundle pricing is mostly designed. When the conversion clears and Apple approves, we'll announce — not before.</div>
        </div>

        <div class="faq-item">
          <div class="faq-q">Where is my data stored?</div>
          <div class="faq-a">Vaultyx files are encrypted on your device, then replicated across 3 datacenters: Vint Hill (Virginia, US), Beauharnois (Canada), and our Contabo node (US). That's 2 jurisdictions, replication factor 2 — every block exists in at least 2 zones. A regional outage doesn't lose your files. No EU node yet — we don't pretend otherwise.</div>
        </div>

      </div>

    </div>
  </main>

  <script slot="scripts" is:inline set:html={`
  document.querySelectorAll('.faq-item').forEach(item => {
    item.querySelector('.faq-q').addEventListener('click', () => {
      item.classList.toggle('open');
    });
  });
`}></script>
</Base>
